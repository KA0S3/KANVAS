VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_PAYSTACK_PUBLIC_KEY=

# R2 Storage Configuration
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Owner Key Configuration
# Option 1: Direct JWK (recommended for development)
VITE_OWNER_KEY_JWK='{"kty":"RSA","n":"...","e":"AQAB"}'

# Option 2: JWK URL (recommended for production)
VITE_OWNER_KEY_JWK_URL=https://your-domain.com/.well-known/jwks.json

# Supabase Functions Environment Variables (set in Supabase dashboard)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# PAYSTACK_SECRET_KEY=
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=
