# Client-side Environment Variables (exposed to browser - must have VITE_ prefix)
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_PAYSTACK_PUBLIC_KEY=your_paystack_public_key

# Server-side Environment Variables (never exposed to browser)
# Cloudflare R2 Storage Configuration
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=your_bucket_name
R2_API_TOKEN=your_r2_api_token

# Paystack Configuration (server-side)
PAYSTACK_SECRET_KEY=your_paystack_secret_key

# JWK URL (recommended for production)
VITE_OWNER_KEY_JWK_URL=https://your-domain.vercel.app/.well-known/jwks.json

# Application Configuration
NODE_ENV=production
PORT=3000

# Owner Configuration
OWNER_EMAIL=owner@example.com

# Supabase Service Role Key (server-side only - keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Optional: Additional security headers
VITE_APP_NAME=KANVAS